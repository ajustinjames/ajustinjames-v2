---
import { Icon } from "astro-icon/components";
const currentPath = Astro.url.pathname;
---

<header>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<nav
			class="flex h-16 items-center justify-between"
			aria-label="Main navigation"
		>
			<a
				href="/"
				class="text-2xl font-medium flex items-center hover:text-primary transition-colors"
				id="home"
				aria-label="ajustinjames - return to homepage">ajustinjames</a
			>
			<div class="flex gap-6 items-center">
				<ul class="flex gap-8 items-center">
						<li class="flex items-center">
						<a
							href="/projects"
							class="hover:text-primary text-lg transition-colors"
							aria-current={currentPath === "/projects" ? "page" : undefined}
							>Projects</a
						>
					</li>
					<li class="flex items-center">
						<a
							href="/blog"
							class="hover:text-primary text-lg transition-colors"
							aria-current={currentPath.startsWith("/blog") ? "page" : undefined}
							>Blog</a
						>
					</li>
				</ul>
				<div class="flex items-center">
					<button
						id="theme-toggle"
						class="hover:text-primary text-lg flex items-center transition-colors"
						onclick="toggleTheme()"
						aria-label="Toggle dark mode"
						aria-pressed="false"
						type="button"
					>
						<Icon
							name="line-md:sunny"
							size="22px"
							class="dark:hidden"
							aria-hidden="true"
						/>
						<Icon
							name="line-md:moon"
							size="22px"
							class="hidden dark:block"
							aria-hidden="true"
						/>
					</button>
				</div>
			</div>
		</nav>
	</div>
</header>

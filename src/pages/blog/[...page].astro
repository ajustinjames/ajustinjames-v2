---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';
import Layout from '../../layouts/Layout.astro';
import BlogPostCard from '../../components/blog/BlogPostCard.astro';
import { getCollection } from 'astro:content';

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog');
  const sortedPosts = allPosts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
  );
  return paginate(sortedPosts, { pageSize: 6 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
---

<Layout title="Blog" description="Blog Homepage">
    <div class="max-w-4xl mx-auto py-8">
        <header class="mb-12">
            <h1 class="text-3xl font-bold">Recent Posts</h1>
            <p class="text-lg text-lightTextSecondary dark:text-darkTextSecondary">Thoughts on software development, technology, gaming, and more!</p>
        </header>

        <ul class="grid gap-6 md:grid-cols-2">
            {page.data.map((post) => (
                <li>
                    <BlogPostCard
                        url={`/posts/${post.slug}`}
                        title={post.data.title}
                        description={post.data.description}
                        pubDate={post.data.pubDate}
                        tags={post.data.tags}
                    />
                </li>
            ))}
        </ul>

        {page.lastPage > 1 && (
            <nav aria-label="Blog pagination" class="mt-12 flex justify-center gap-4">
                {page.url.prev ? (
                    <a href={page.url.prev} class="hl-card-shell px-4 py-2 hover-lift no-underline text-lightTextPrimary dark:text-darkTextPrimary hover:text-primary">
                        &larr; Previous
                    </a>
                ) : (
                    <span class="px-4 py-2 text-lightTextSecondary dark:text-darkTextSecondary opacity-40">
                        &larr; Previous
                    </span>
                )}
                <span class="flex items-center text-lightTextSecondary dark:text-darkTextSecondary">
                    Page {page.currentPage} of {page.lastPage}
                </span>
                {page.url.next ? (
                    <a href={page.url.next} class="hl-card-shell px-4 py-2 hover-lift no-underline text-lightTextPrimary dark:text-darkTextPrimary hover:text-primary">
                        Next &rarr;
                    </a>
                ) : (
                    <span class="px-4 py-2 text-lightTextSecondary dark:text-darkTextSecondary opacity-40">
                        Next &rarr;
                    </span>
                )}
            </nav>
        )}
    </div>
</Layout>

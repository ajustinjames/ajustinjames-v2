---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page Not Found" description="The page you were looking for doesn't exist.">
	<div class="flex flex-col items-center justify-center text-center py-24">
		<h1 class="text-8xl font-bold text-primary mb-4">404</h1>
		<h2 class="text-2xl font-semibold mb-4">Page Not Found</h2>
		<p class="text-lightTextSecondary dark:text-darkTextSecondary mb-8 max-w-md">
			The page you were looking for doesn't exist or has been moved.
		</p>
		<a
			href="/"
			class="px-6 py-3 bg-primary hover:bg-primaryHover text-white font-semibold shadow-[var(--hl-alias-shadow-1)] transition-colors"
		>
			Back to Home
		</a>
	</div>
</Layout>

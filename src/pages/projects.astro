---
import Layout from "../layouts/Layout.astro";
import { projects } from "../data/projects";
---

<Layout title="Projects" description="A showcase of personal projects and side apps by Aaron James.">
	<div class="max-w-4xl mx-auto px-4 py-12">
		<header class="mb-12">
			<h1 class="text-3xl font-bold">Projects</h1>
			<p class="text-lg text-lightTextSecondary dark:text-darkTextSecondary mt-2">Things I've built</p>
		</header>

		<ul class="grid gap-6 md:grid-cols-2">
			{projects.map((project) => (
				<li class="group rounded-lg border border-borderLight dark:border-borderDark bg-cardLightBg dark:bg-cardDarkBg p-6 transition-all hover:shadow-lg hover:border-primary">
					<h2 class="text-xl font-semibold text-lightTextPrimary dark:text-darkTextPrimary group-hover:text-primary">
						{project.name}
					</h2>
					<p class="mt-3 text-lightTextSecondary dark:text-darkTextSecondary">
						{project.description}
					</p>
					<div class="mt-4 flex flex-wrap gap-2">
						{project.technologies.map((tech) => (
							<span class="text-xs px-2 py-1 rounded-full bg-surfaceLightHover dark:bg-surfaceDarkHover border border-borderLight dark:border-borderDark">
								{tech}
							</span>
						))}
					</div>
					<div class="mt-4 flex gap-4 text-sm">
						{project.repoUrl && (
							<a
								href={project.repoUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="text-primary hover:underline"
							>
								GitHub
							</a>
						)}
						{project.siteUrl && (
							<a
								href={project.siteUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="text-primary hover:underline"
							>
								Live Site
							</a>
						)}
					</div>
				</li>
			))}
		</ul>
	</div>
</Layout>

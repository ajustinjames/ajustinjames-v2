---
const contactFormUrl: string = import.meta.env.CONTACT_FORM_URL;
const turnstileSiteKey: string = import.meta.env.TURNSTILE_SITE_KEY;
---

<section id="contact" class="py-16 px-4 max-w-6xl mx-auto">
    <h3 class="text-3xl font-bold text-center mb-8">Contact Me</h3>
    <div
        class="hl-card-shell"
    >
        <div id="form-feedback-container" class="mb-6"></div>
        <form id="contact-form" method="POST" class="space-y-6">
            <div set:html={`<hl-input label-for="contact-name"><label slot="label" for="contact-name">Name</label><input type="text" id="contact-name" name="name" required /></hl-input>`} />
            <div set:html={`<hl-input label-for="contact-email"><label slot="label" for="contact-email">Email</label><input type="email" id="contact-email" name="email" required /></hl-input>`} />
            <div set:html={`<hl-input label-for="contact-message"><label slot="label" for="contact-message">Message</label><textarea id="contact-message" name="message" required rows="5"></textarea></hl-input>`} />
            <div class="flex flex-wrap items-center justify-between gap-4 mt-4">
                <div class="flex items-center gap-4">
                    <span set:html={`<hl-btn variant="primary" size="md"><button type="submit" id="submit-btn">Send</button></hl-btn>`} />
                    <span set:html={`<hl-btn variant="ghost" size="md"><button type="reset">Clear</button></hl-btn>`} />
                    <hl-spinner id="submit-spinner" size="sm" label="Sending..." hidden></hl-spinner>
                </div>
                {
                    turnstileSiteKey && (
                        <div class="cf-turnstile w-full sm:w-auto" data-sitekey={turnstileSiteKey} data-size="flexible"></div>
                    )
                }
            </div>
        </form>
    </div>
</section>

<script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
    is:inline></script>

<script define:vars={{ contactFormUrl }} is:inline>
    const form = document.getElementById("contact-form");
    const feedbackContainer = document.getElementById("form-feedback-container");
    const submitWrapper = document.getElementById("submit-btn")?.closest("hl-btn");
    const submitBtn = document.getElementById("submit-btn");
    const spinner = document.getElementById("submit-spinner");

    // <hl-alert> is created client-side to avoid an SSR crash in
    // @ajustinjames/hardline-components' ds-alert (lit-ssr cannot parse its
    // dynamic `style="--hl-alert-tone-color:${color}"` attribute binding).
    let feedback = null;

    function showFeedback(message, isSuccess) {
        if (!feedbackContainer) return;
        if (!feedback) {
            feedback = document.createElement("hl-alert");
            feedback.id = "form-feedback";
            feedback.setAttribute("aria-live", "polite");
            feedbackContainer.appendChild(feedback);
        }
        feedback.textContent = message;
        feedback.setAttribute("tone", isSuccess ? "success" : "error");
        feedback.removeAttribute("hidden");
        if (isSuccess) {
            setTimeout(() => {
                feedback.setAttribute("hidden", "");
            }, 5000);
        }
    }

    function setLoading(isLoading) {
        if (submitWrapper) {
            if (isLoading) {
                submitWrapper.setAttribute("disabled", "");
            } else {
                submitWrapper.removeAttribute("disabled");
            }
        }
        if (submitBtn) submitBtn.disabled = isLoading;
        if (spinner) {
            if (isLoading) {
                spinner.removeAttribute("hidden");
            } else {
                spinner.setAttribute("hidden", "");
            }
        }
    }

    const handleSubmit = async (event) => {
        event.preventDefault();
        event.stopPropagation();

        const formData = new FormData(form);

        setLoading(true);
        try {
            const response = await fetch(contactFormUrl, {
                method: "POST",
                body: formData,
            });

            if (response.ok) {
                showFeedback("Message sent successfully!", true);
                form.reset();
                return false;
            } else {
                const error = await response.text();
                showFeedback(`Error: ${error}`, false);
            }
        } catch (error) {
            console.error("Error submitting form:", error);
            showFeedback("An error occurred while sending your message.", false);
        } finally {
            setLoading(false);
        }
        return false;
    };

    form.addEventListener("submit", handleSubmit);
</script>

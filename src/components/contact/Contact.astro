---
const contactFormUrl: string = import.meta.env.CONTACT_FORM_URL;
---

<section id="contact" class="py-16 px-4 max-w-6xl mx-auto">
    <h3 class="text-3xl font-bold text-center mb-8">Contact Me</h3>
    <div
        class="p-8 border border-borderLight dark:border-borderDark rounded-lg shadow-md bg-cardLightBg dark:bg-cardDarkBg"
    >
        <div
            id="form-feedback"
            class="hidden mb-6 px-4 py-3 rounded-md border text-sm font-medium"
            role="alert"
            aria-live="polite"
        ></div>
        <form id="contact-form" method="POST" class="space-y-6">
            <label class="block space-y-2">
                <span class="text-sm font-medium">Name</span>
                <input
                    type="text"
                    name="name"
                    required
                    class="block w-full px-4 py-3 bg-surfaceLight dark:bg-surfaceDark border border-borderLight dark:border-borderDark text-lightTextPrimary dark:text-darkTextPrimary rounded-md shadow-sm focus:ring-1 focus:ring-primary"
                />
            </label>
            <label class="block space-y-2">
                <span class="text-sm font-medium">Email</span>
                <input
                    type="email"
                    name="email"
                    required
                    class="block w-full px-4 py-3 bg-surfaceLight dark:bg-surfaceDark border border-borderLight dark:border-borderDark text-lightTextPrimary dark:text-darkTextPrimary rounded-md shadow-sm focus:ring-1 focus:ring-primary"
                />
            </label>
            <label class="block space-y-2">
                <span class="text-sm font-medium">Message</span>
                <textarea
                    name="message"
                    required
                    class="block w-full px-4 py-3 bg-surfaceLight dark:bg-surfaceDark border border-borderLight dark:border-borderDark text-lightTextPrimary dark:text-darkTextPrimary rounded-md shadow-sm focus:ring-1 focus:ring-primary resize-none"
                    rows="5"></textarea>
            </label>
            <div class="flex flex-wrap items-center justify-between gap-4 mt-4">
                <div class="flex items-center gap-4">
                    <button
                        type="submit"
                        class="h-[48px] max-h-[48px] py-3 px-6 bg-primary hover:bg-primaryHover text-white font-semibold rounded-md shadow-md transition-all sm:w-auto"
                    >
                        Submit
                    </button>
                    <button
                        type="reset"
                        class="h-[48px] max-h-[48px] py-3 px-6 text-lightTextPrimary dark:text-darkTextPrimary bg-surfaceLight dark:bg-surfaceDark border border-borderLight dark:border-borderDark rounded-md hover:bg-gray-100 dark:hover:bg-gray-700 transition-all font-semibold shadow-md sm:w-auto"
                    >
                        Clear
                    </button>
                </div>
                <div
                    class="cf-turnstile"
                    data-sitekey={import.meta.env.TURNSTILE_SITE_KEY}
                >
                </div>
            </div>
        </form>
    </div>
</section>

<script
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
    is:inline></script>

<script define:vars={{ contactFormUrl }} is:inline>
    const form = document.getElementById("contact-form");
    const feedback = document.getElementById("form-feedback");

    function showFeedback(message, isSuccess) {
        if (!feedback) return;
        feedback.textContent = message;
        feedback.className = isSuccess
            ? "mb-6 px-4 py-3 rounded-md border text-sm font-medium bg-green-50 border-green-300 text-green-800 dark:bg-green-900/20 dark:border-green-700 dark:text-green-300"
            : "mb-6 px-4 py-3 rounded-md border text-sm font-medium bg-red-50 border-red-300 text-red-800 dark:bg-red-900/20 dark:border-red-700 dark:text-red-300";
        if (isSuccess) {
            setTimeout(() => {
                feedback.className = "hidden mb-6 px-4 py-3 rounded-md border text-sm font-medium";
            }, 5000);
        }
    }

    const handleSubmit = async (event) => {
        event.preventDefault();
        event.stopPropagation();

        const formData = new FormData(form);

        try {
            const response = await fetch(contactFormUrl, {
                method: "POST",
                body: formData,
            });

            if (response.ok) {
                showFeedback("Message sent successfully!", true);
                form.reset();
                return false;
            } else {
                const error = await response.text();
                showFeedback(`Error: ${error}`, false);
            }
        } catch (error) {
            console.error("Error submitting form:", error);
            showFeedback("An error occurred while sending your message.", false);
        }
        return false;
    };

    form.addEventListener("submit", handleSubmit);
</script>

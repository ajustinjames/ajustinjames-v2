---
import { Icon } from "astro-icon/components";
import { socialLinks } from "../../data/social-links";

const years = (new Date().getFullYear() - 2019).toString();
---

<section
	class="flex flex-col justify-center items-center text-center py-16 md:py-24"
>
	<div class="mb-8">
		<img
			src="/ajlogo.svg"
			alt="Logo"
			class="w-48 h-48 mx-auto transition-transform duration-300 motion-safe:hover:scale-105"
			loading="lazy"
		/>
	</div>
	<div class="mb-6">
		<h1 class="text-4xl md:text-6xl font-bold text-primary">Aaron James</h1>
		<h2 class="text-xl md:text-2xl font-mono font-semibold text-lightTextSecondary dark:text-darkTextSecondary mt-3">
			Software Engineer
		</h2>
		<p
			class="text-base md:text-lg mt-4 max-w-2xl mx-auto text-lightTextPrimary dark:text-darkTextPrimary"
		>
			I've spent over {years} years building web and mobile apps. I love tackling
			tough problems and finding smart solutions. Tech is always changing,
			and I'm always learning. That's what keeps this work exciting.
		</p>
	</div>
	<div class="mb-6">
		<div class="flex justify-center space-x-4 mb-6">
			{socialLinks.map((link) => (
				<a
					href={link.href}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={link.label}
					class="p-2 hover:text-primary transition-transform duration-150 motion-safe:hover:scale-125"
				>
					<Icon name={link.iconName} size="48px" />
				</a>
			))}
		</div>
		<div class="flex justify-center items-center">
			<button
				class="text-lightTextPrimary dark:text-darkTextPrimary transition-colors duration-300"
				onclick="document.querySelector('#skills').scrollIntoView({ behavior: 'smooth' })"
				aria-label="Scroll down to skills section"
			>
				<Icon
					name="line-md:chevron-down-circle"
					size="32px"
					aria-hidden="true"
					class="transition-all duration-100 motion-safe:hover:border-2 motion-safe:hover:border-borderLight dark:motion-safe:hover:border-borderDark motion-safe:hover:rounded-full"
				/>
			</button>
		</div>
	</div>
</section>

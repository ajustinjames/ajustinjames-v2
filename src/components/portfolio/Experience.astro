---
import { experience, formatDate, duration } from "../../data/experience";

function companyRange(roles: typeof experience[number]["roles"]) {
    const starts = roles.map((r) => r.startYear * 12 + r.startMonth);
    const minStart = Math.min(...starts);
    const start = roles.find((r) => r.startYear * 12 + r.startMonth === minStart)!;

    const hasOngoing = roles.some((r) => r.endYear === null);
    if (hasOngoing) {
        return {
            start: { year: start.startYear, month: start.startMonth },
            end: null,
        };
    }

    const ends = roles.map((r) => r.endYear! * 12 + r.endMonth!);
    const maxEnd = Math.max(...ends);
    const end = roles.find((r) => r.endYear! * 12 + r.endMonth! === maxEnd)!;

    return {
        start: { year: start.startYear, month: start.startMonth },
        end: { year: end.endYear!, month: end.endMonth! },
    };
}
---

<section id="experience" class="py-16 px-4 max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">Work Experience</h2>
    <div class="space-y-6">
        {
            experience.map((company) => {
                const range = companyRange(company.roles);
                return (
                    <div class="hl-card-shell">
                        <div class="flex items-center gap-2">
                            <h3 class="text-xl font-semibold">{company.company}</h3>
                            <span class="text-md text-lightTextSecondary dark:text-darkTextSecondary">
                                {company.location}
                            </span>
                        </div>
                        {company.roles.length > 1 && (
                            <p class="text-sm text-lightTextSecondary dark:text-darkTextSecondary">
                                {formatDate(range.start.year, range.start.month)} - {range.end ? formatDate(range.end.year, range.end.month) : "Present"}{" "}
                                {duration(range.start, range.end)}
                            </p>
                        )}
                        <div class="space-y-4 mt-2">
                            {company.roles.map((role) => (
                                <div>
                                    <h4 class="text-lg font-medium">
                                        {role.title}
                                    </h4>
                                    <p class="text-sm text-lightTextSecondary dark:text-darkTextSecondary">
                                        {formatDate(role.startYear, role.startMonth)} - {role.endYear !== null ? formatDate(role.endYear, role.endMonth!) : "Present"}{" "}
                                        {duration({ year: role.startYear, month: role.startMonth }, role.endYear !== null ? { year: role.endYear, month: role.endMonth! } : null)}
                                    </p>
                                    <ul class="list-disc ml-5 mt-2">
                                        {role.details.map((detail) => (
                                            <li>{detail}</li>
                                        ))}
                                    </ul>
                                    {role.technologies.length > 0 && (
                                        <p class="mt-2 text-sm">
                                            <strong>Technologies:</strong>{" "}
                                            {role.technologies.join(", ")}
                                        </p>
                                    )}
                                </div>
                            ))}
                        </div>
                    </div>
                );
            })
        }
    </div>
</section>
